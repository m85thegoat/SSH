class TelegramNotifier:
    """Send TEXT notifications to Telegram (No files)"""

    def __init__(self, token=TELEGRAM_BOT_TOKEN, chat_id=TELEGRAM_CHAT_ID):
        self.token = token
        self.chat_id = chat_id
        self.base_url = f"https://api.telegram.org/bot{token}"
        self.vps_batch = []
        self.batch_size = 5

    def send_message(self, message):
        """Send text message to Telegram"""
        try:
            url = f"{self.base_url}/sendMessage"
            data = {
                "chat_id": self.chat_id,
                "text": message,
                "parse_mode": "HTML"
            }
            response = requests.post(url, data=data, timeout=10)
            return response.status_code == 200
        except Exception as e:
            print(f"[!] Telegram error: {e}")
            return False

    def send_vps_found(self, ip, banner):
        """Send VPS found notification (TEXT only)"""
        message = f"""🔍 <b>SSH SERVER FOUND!</b>

🌐 IP: <code>{ip}</code>
🖥️ Banner: <code>{banner or 'Unknown'}</code>
📅 Time: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}

🔎 Running vulnerability scan..."""
        return self.send_message(message)

